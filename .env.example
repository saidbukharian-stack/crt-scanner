# Bu faylni ".env" nomi bilan nusxalang va o'z qiymatlaringizni kiriting.
# .env faylini hech qachon git'ga yubormang (agar git ishlatsangiz).

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Narx manbai: mt5 (lokal Windows+terminal) yoki oanda (bulut uchun)
DATA_SOURCE=mt5

# OANDA demo hisob tokeni (DATA_SOURCE=oanda bo'lsa kerak)
# Olish: oanda.com -> demo hisob -> Manage API Access
OANDA_API_TOKEN=
